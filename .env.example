PORT=3000
JWT_SECRET=your_jwt_secret_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Claude model alias: sonnet-4, sonnet-3.5, opus, opus-3, haiku  (or a full model ID)
CLAUDE_MODEL=sonnet-4
# Max number of tracker checks that run in parallel (default: 5)
CHECK_CONCURRENCY=5

# Optional CORS allowlist for credentialed cross-origin requests.
# Comma-separated origins only (scheme + host + optional port).
# Example: CORS_ALLOWED_ORIGINS=https://watchbot.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=

# AWS SES email notifications (optional)
# IAM user must have ses:SendEmail permission for the verified SES_FROM identity
SES_REGION=your_ses_region_here
SES_ACCESS_KEY_ID=your_ses_access_key_id
SES_SECRET_ACCESS_KEY=your_ses_secret_access_key
SES_FROM=Watchbot <watchbot@yourdomain.com>

# Dedicated IAM user for S3 media writes (s3:PutObject, s3:HeadObject on S3_MEDIA_BUCKET)
S3_REGION=your_s3_region_here
S3_ACCESS_KEY_ID=your_s3_access_key_id
S3_SECRET_ACCESS_KEY=your_s3_secret_access_key
S3_MEDIA_BUCKET=your_s3_media_bucket
CDN_BASE_URL=your_cdn_base_url

# Dedicated IAM user for CloudFront invalidations (cloudfront:CreateInvalidation)
CF_ACCESS_KEY_ID=your_cf_access_key_id
CF_SECRET_ACCESS_KEY=your_cf_secret_access_key
